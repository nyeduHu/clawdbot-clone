# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application Client ID
CLIENT_ID=your_client_id_here

# Discord Bot Owner ID (your Discord user ID, for admin commands)
OWNER_ID=your_discord_user_id_here

# Gemini API Key (from https://aistudio.google.com/apikey — free)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Channel IDs where the bot responds to all messages (comma-separated)
# If empty, bot only responds to @mentions and DMs
AI_CHANNEL_IDS=
